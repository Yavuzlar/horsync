# =========================================
# Horsync Configuration
# Copy this file to .env and customize:
#   cp .env.example .env
# =========================================

# HTTP address for the central Hub server
# Format: :port (e.g., :3001)
APP_ADDR=:3001

# PostgreSQL database connection string
# Note: The Docker Compose setup uses port 5433 to avoid conflicts
DATABASE_URL=postgres://horsync:horsync123@localhost:5433/horsync?sslmode=disable

# Directory for storing uploaded files (relative to project root)
UPLOAD_STORAGE_PATH=data/uploads

# Maximum chunk size in bytes for file transfer (default: 2MB)
MAX_CHUNK_SIZE_BYTES=2097152
